rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName'])
        && data.uid == request.auth.uid
        && (data.get('email', '') == null || data.get('email', '') is string)
        && data.displayName is string && data.displayName.size() < 100
        && (data.get('photoURL', '') == null || data.get('photoURL', '') is string)
        && (data.get('username', '') == null || data.get('username', '') is string)
        && (data.get('usernameUpdatedAt', null) == null || data.get('usernameUpdatedAt', null) is timestamp)
        && (data.get('hideName', null) == null || data.get('hideName', null) is bool)
        && (data.get('customName', '') == null || data.get('customName', '') is string)
        && (data.get('status', 'offline') in ['online', 'offline']);
    }

    function isValidChat(data) {
      return data.participantIds is list
        && data.participantIds.size() >= 1
        && data.participantIds.size() <= 10
        && request.auth.uid in data.participantIds
        && data.updatedAt == request.time;
    }

    function isValidMessage(data, chatId) {
      // Relational check: sender must be participant in parent chat
      return data.keys().hasAll(['senderId', 'timestamp', 'type'])
        && data.senderId == request.auth.uid
        && data.timestamp == request.time
        && data.type in ['text', 'image', 'file', 'voice']
        && (data.type != 'text' || (data.get('text', '') is string && data.get('text', '').size() <= 5000))
        && (data.type == 'text' || (data.get('url', '') is string && data.get('url', '').size() <= 1024))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isSignedIn(); // Allow discovery
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastSeen', 'status', 'username', 'email', 'usernameUpdatedAt', 'hideName', 'customName'])
        && (
          !incoming().diff(existing()).affectedKeys().hasAny(['username']) 
          || (
            incoming().usernameUpdatedAt == request.time 
            && (
              existing().get('usernameUpdatedAt', null) == null 
              || existing().get('usernameUpdatedAt', null).toMillis() + (24 * 60 * 60 * 1000) <= request.time.toMillis()
            )
          )
        );
    }

    match /chats/{chatId} {
      allow list: if isSignedIn() && resource.data.participantIds.hasAny([request.auth.uid]);
      allow get: if isSignedIn() && (resource == null || resource.data.participantIds.hasAny([request.auth.uid]));
      
      allow create: if isSignedIn() && isValidChat(incoming()) && isValidId(chatId);
      
      allow update: if isSignedIn()
        && existing().participantIds.hasAny([request.auth.uid])
        && incoming().participantIds == existing().participantIds // Participants cannot be changed by client easily
        && (
          // Action: Update metadata on new message
          incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'lastMessageSenderId', 'updatedAt'])
          && incoming().updatedAt == request.time
        );

      allow delete: if isSignedIn() && existing().participantIds.hasAny([request.auth.uid]);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow list, get: if isSignedIn()
        && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
      
      allow create: if isSignedIn() && isValidMessage(incoming(), chatId) && isValidId(messageId);
      // Messages are immutable in this version, but can be deleted by sender
      allow update: if false;
      allow delete: if isSignedIn() && existing().senderId == request.auth.uid;
    }

    match /chats/{chatId}/typing/{userId} {
      // Any participant can read typing status
      allow read: if isSignedIn() 
        && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
      
      // User can only update their own typing status if they are a participant
      allow write: if isOwner(userId)
        && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid])
        && (request.method == 'create' || request.method == 'update')
        && incoming().keys().hasAll(['isTyping', 'updatedAt'])
        && incoming().isTyping is bool
        && incoming().updatedAt == request.time;
    }

    match /calls/{callId} {
      allow list, get: if isSignedIn() && (resource == null || resource.data.participantIds.hasAny([request.auth.uid]));
      allow create: if isSignedIn()
        && incoming().keys().hasAll(['participantIds', 'status', 'callerId', 'createdAt', 'updatedAt'])
        && incoming().participantIds is list
        && request.auth.uid in incoming().participantIds
        && incoming().callerId == request.auth.uid
        && isValidId(callId);
      
      allow update: if isSignedIn()
        && existing().participantIds.hasAny([request.auth.uid])
        && incoming().participantIds == existing().participantIds
        && incoming().diff(existing()).affectedKeys().hasAny(['status', 'offer', 'answer', 'updatedAt'])
        && incoming().updatedAt == request.time;
      
      allow delete: if isSignedIn() && existing().participantIds.hasAny([request.auth.uid]);
      
      match /callerCandidates/{candidateId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/calls/$(callId)).data.participantIds.hasAny([request.auth.uid]);
        allow create: if isSignedIn() 
          && get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid;
      }
      
      match /receiverCandidates/{candidateId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/calls/$(callId)).data.participantIds.hasAny([request.auth.uid]);
        allow create: if isSignedIn() 
          && get(/databases/$(database)/documents/calls/$(callId)).data.participantIds.hasAny([request.auth.uid])
          && get(/databases/$(database)/documents/calls/$(callId)).data.callerId != request.auth.uid;
      }
    }
  }
}
