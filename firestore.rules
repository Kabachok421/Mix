rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName'])
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() < 256
        && data.displayName is string && data.displayName.size() < 100
        && (data.get('photoURL', '') is string)
        && (data.get('status', 'offline') in ['online', 'offline']);
    }

    function isValidChat(data) {
      return data.participantIds is list
        && data.participantIds.size() >= 1
        && data.participantIds.size() <= 10
        && request.auth.uid in data.participantIds
        && data.updatedAt == request.time;
    }

    function isValidMessage(data, chatId) {
      // Relational check: sender must be participant in parent chat
      return data.keys().hasAll(['text', 'senderId', 'timestamp'])
        && data.senderId == request.auth.uid
        && data.text is string && data.text.size() <= 5000
        && data.timestamp == request.time
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isSignedIn(); // Allow discovery
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'photoURL', 'lastSeen', 'status']);
    }

    match /chats/{chatId} {
      allow list: if isSignedIn() && resource.data.participantIds.hasAny([request.auth.uid]);
      allow get: if isSignedIn() && resource.data.participantIds.hasAny([request.auth.uid]);
      
      allow create: if isSignedIn() && isValidChat(incoming()) && isValidId(chatId);
      
      allow update: if isSignedIn()
        && existing().participantIds.hasAny([request.auth.uid])
        && incoming().participantIds == existing().participantIds // Participants cannot be changed by client easily
        && (
          // Action: Update metadata on new message
          incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'lastMessageSenderId', 'updatedAt'])
          && incoming().updatedAt == request.time
        );
    }

    match /chats/{chatId}/messages/{messageId} {
      allow list, get: if isSignedIn()
        && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
      
      allow create: if isSignedIn() && isValidMessage(incoming(), chatId) && isValidId(messageId);
      // Messages are immutable in this version
      allow update, delete: if false;
    }

    match /chats/{chatId}/typing/{userId} {
      // Any participant can read typing status
      allow read: if isSignedIn() 
        && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
      
      // User can only update their own typing status if they are a participant
      allow write: if isOwner(userId)
        && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid])
        && (request.method == 'create' || request.method == 'update')
        && incoming().keys().hasAll(['isTyping', 'updatedAt'])
        && incoming().isTyping is bool
        && incoming().updatedAt == request.time;
    }
  }
}
