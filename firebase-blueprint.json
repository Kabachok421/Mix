{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["online", "offline"] }
      },
      "required": ["uid", "email", "displayName"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Metadata for a conversation between users",
      "type": "object",
      "properties": {
        "participantIds": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageSenderId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participantIds", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat metadata documents"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat"
    }
  }
}
